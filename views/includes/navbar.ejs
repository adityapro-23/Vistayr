<style>
	.search-btn {
		background-color: #001F5B;
		/* background-color: #553265; */
		color: #fff;
		border-radius: 25px;
		padding: 0 1rem 0 1rem;
	}

	.search-btn:hover {
		background-color: #002775e1;
		color: #fff;
		transition: 0.3s ease-out;
	}
	
	.search-btn i {
		display: inline;
		margin-right: 0.5rem;
	}

	.search-inp {
		border-radius: 25px;
		padding: 0.5rem 3rem 0.5rem 3rem;
		border-color: #001F5B;
	}

</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
    <div class="container-fluid">
		<a class="navbar-brand" href="/listings"><img src="/Vistayr_logo.png" alt="Vistayr Logo" height="70"></a>
		<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>
		<div class="collapse navbar-collapse" id="navbarNavAltMarkup">
			<div class="navbar-nav">
				<a class="nav-link" href="/listings">Vistayr</a>
			</div>
			<div class="navbar-nav ms-auto">
				<form class="d-flex" role="search" method="GET" action="/listings/results">
					<input class="form-control me-2 search-inp" type="search" placeholder="Search destinations" name="search">	
					<button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
				</form>
			</div>
			<div class="navbar-nav ms-auto">
				<a class="nav-link" href="/listings/new">Host a stay</a>
				<% if(currUser) { %>
					<div class="dropdown">
						<a class="btn btn-secondary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
							<img src="<%= currUser.profilePicture || '/default-profile.png' %>" class="profile-pic rounded-circle" alt="Profile">
						</a>
						
						<ul class="dropdown-menu dropdown-menu-end">
						  <% if(currUser.role === "host") { %>
							<li><a class="dropdown-item" href="/dashboard">Dashboard</a></li>
						  <% } %>
						  <li><a class="dropdown-item" href="/bookings">My Bookings</a></li>
						  <li><a class="dropdown-item" href="/wishlist">Wishlist</a></li>
						  <li><hr class="dropdown-divider"></li>
						  <li><a class="dropdown-item" href="/help">Help Centre</a></li>
						  <li><a class="dropdown-item" href="/logout">Logout</a></li>
						</ul>
					  </div>
					
				<% } else { %>
					<a class="nav-link" href="/signup"><b>Sign up</b></a>
					<a class="nav-link" href="/login"><b>Log in</b></a>
				<% } %>
			</div>
		</div>
    </div>
  </nav>