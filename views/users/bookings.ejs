<% layout("/layouts/boilerplate") %>

<h1><%= currUser.username %>'s Bookings</h1>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% if (bookings.length === 0) { %>
        <p style="margin: auto; width: 30%; margin-top: 7rem; font-size: larger;">You do not have any bookings!</p>
    <% } else { %>
        <% bookings.forEach(booking => { %>
            <a href="/listings/<%= booking.listing._id %>" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= booking.listing.title %></b> <br>
                            Check-in:&nbsp;<i><%= booking.startDate.toLocaleDateString("en-IN") %></i> &nbsp;&nbsp;|&nbsp;&nbsp; Check-out: <i><%= booking.endDate.toLocaleDateString("en-IN") %></i> <br>
                            Sub-Total:&nbsp; &#8377; <%= booking.totalPrice.toLocaleString("en-IN") %>
                            &nbsp;&nbsp;|&nbsp;&nbsp;
                            Status:&nbsp; <b class="dynamicbg rounded-pill" style="color: black;">&nbsp;<%= booking.status.toUpperCase() %>&nbsp;</b>
                        </p>
                        <% if (booking.status !== "canceled" && booking.status !== "completed") { %>
                            <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST">
                                <button class="btn btn-danger btn-sm">Cancel</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </a>
        <% }) %>
    <% } %>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let statusElements = document.getElementsByClassName("dynamicbg");
        for (let el of statusElements) {
            let status = el.innerText.trim().toUpperCase();
            switch (status) {
                case "CANCELED":
                    el.style.backgroundColor = "#dc3545"; 
                    el.style.color = "white";
                    break;
                case "CONFIRMED":
                    el.style.backgroundColor = "#28a745"; 
                    el.style.color = "white";
                    break;
                case "WAITING":
                    el.style.backgroundColor = "#ffc107";
                    el.style.color = "white";
                    break;
                case "COMPLETED":
                    el.style.backgroundColor = "#007bff"; 
                    el.style.color = "white";
                    break;
                default:
                    el.style.backgroundColor = "#6c757d"; 
                    el.style.color = "white";
                    break;
            }
        }
    });
</script>
