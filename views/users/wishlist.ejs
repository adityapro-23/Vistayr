<% layout("/layouts/boilerplate") %>

<h1><%= currUser.username %>'s Wishlist</h1>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% if (wishlist.length === 0) { %>
        <p style="margin: auto; width: 20%; font-size: larger;">Your wishlist is empty!</p>
    <% } else { %>
        <% wishlist.forEach(listing => { %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b> <br>
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                        </p>
                        <form action="/wishlist/<%= listing._id %>?_method=DELETE" method="POST">
                            <button class="btn removeFromWishlistBtn btn-sm">Remove</button>
                        </form>
                    </div>
                </div>
            </a>
        <% }) %>
    <% } %>
</div>